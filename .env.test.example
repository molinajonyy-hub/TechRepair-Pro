# Variables de entorno para tests E2E
# Copiar a .env.test y completar con valores reales.
# NUNCA commitear .env.test con credenciales reales.

# URL del servidor local (dev server o staging)
E2E_BASE_URL=http://localhost:5173

# Usuario QA — crear en Supabase Auth con negocio configurado
# NO usar cuenta de negocio real
E2E_EMAIL=qa@techrepair.test
E2E_PASSWORD=QA_password_here
