# ─────────────────────────────────────────────────────────────────────────────
# TechRepair Pro — Variables de entorno para tests E2E
# ─────────────────────────────────────────────────────────────────────────────
#
# Cómo usar:
#   cp .env.test.example .env.test
#   Completar .env.test manualmente con valores reales.
#
# REGLAS:
#   - NUNCA commitear .env.test con credenciales reales.
#   - NUNCA hardcodear credenciales en código fuente o tests.
#   - Usar un usuario QA dedicado, NO una cuenta de negocio real.
#   - No correr tests @finance ni @stock contra producción sin datos aislados.
#   - Los datos creados por los tests usan prefijo "E2E " y se pueden limpiar manualmente.
# ─────────────────────────────────────────────────────────────────────────────

# URL del servidor local (dev server)
# Valores posibles: http://localhost:5173 | http://localhost:4173 (preview)
E2E_BASE_URL=http://localhost:5173

# Supabase — necesario para que el dev server conecte a la DB QA
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Usuario QA — crear en Supabase Auth con negocio de prueba configurado
# NO usar cuenta de negocio real
E2E_EMAIL=COMPLETAR_MANUALMENTE
E2E_PASSWORD=COMPLETAR_MANUALMENTE

# ─── Fixtures opcionales (tests usan skip si están vacíos) ───────────────────
# IDs del negocio QA. Si están vacíos, los tests los saltan con .skip()
E2E_BUSINESS_ID=
E2E_CUSTOMER_ID=
E2E_SUPPLIER_ID=
E2E_ORDER_ID=
E2E_COMPROBANTE_ID=
E2E_INVENTORY_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Variables opcionales — necesarias solo para tests @finance con test.fixme
# ─────────────────────────────────────────────────────────────────────────────
# Cómo obtener los IDs:
#   1. Crear los comprobantes manualmente desde la app
#   2. Abrir el comprobante y copiar el UUID de la URL: /comprobantes/<uuid>
#   3. Pegar los IDs aquí
# ─────────────────────────────────────────────────────────────────────────────

# Comprobante pagado con efectivo $1000 (para editar-cobro-unico.spec.ts)
E2E_COMPROBANTE_ID_EFECTIVO=

# Comprobante con pago mixto $500 efectivo + $500 transferencia (para editar-cobro-mixto.spec.ts)
E2E_COMPROBANTE_ID_MIXTO=

# ID de una nota de crédito existente (para nota-credito.spec.ts)
E2E_NOTA_CREDITO_ID=
