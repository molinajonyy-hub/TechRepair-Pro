# ============================================================================
# Dev local contra Supabase LOCAL (evita pegarle a PRODUCCIÓN por accidente).
#
# Copiá este archivo a .env.local:
#     cp .env.local.example .env.local
# Vite le da prioridad a .env.local por sobre .env, y .env.local está gitignored.
#
# ⚠️ El .env (local, no versionado) suele apuntar a la Supabase de PRODUCCIÓN.
#    Para desarrollo/smoke financiero SIEMPRE usá .env.local apuntando a local.
#    Ver docs/ops/local-env-safety.md
# ============================================================================

# API local de Supabase (npx supabase start). Confirmá el puerto con:
#     npx supabase status   ->   API_URL
VITE_SUPABASE_URL=http://127.0.0.1:54621

# anon key LOCAL por defecto de Supabase (pública, NO es un secreto: es la misma
# demo key en toda instalación local). Confirmá con `npx supabase status` -> ANON_KEY.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
