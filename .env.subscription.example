# ============================================================
# Mercado Pago Subscription — Environment Variables
# Copy these to your .env.local (frontend) and Supabase secrets (Edge Functions)
# ============================================================

# ─── Frontend (.env.local) ───────────────────────────────────
# MP Preapproval Plan IDs (create them in MP dashboard → Suscripciones → Planes)
VITE_MP_PLAN_BASICO_MONTHLY=2c938084XXXXXXXXXX
VITE_MP_PLAN_BASICO_QUARTERLY=2c938084XXXXXXXXXX
VITE_MP_PLAN_BASICO_ANNUAL=2c938084XXXXXXXXXX

VITE_MP_PLAN_PRO_MONTHLY=2c938084XXXXXXXXXX
VITE_MP_PLAN_PRO_QUARTERLY=2c938084XXXXXXXXXX
VITE_MP_PLAN_PRO_ANNUAL=2c938084XXXXXXXXXX

VITE_MP_PLAN_FULL_MONTHLY=2c938084XXXXXXXXXX
VITE_MP_PLAN_FULL_QUARTERLY=2c938084XXXXXXXXXX
VITE_MP_PLAN_FULL_ANNUAL=2c938084XXXXXXXXXX

# Already present:
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJxxxx

# ─── Supabase Edge Function Secrets ──────────────────────────
# Run: supabase secrets set KEY=VALUE
#
# MP_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX
# MP_WEBHOOK_SECRET=your-webhook-secret-from-mp-dashboard
# APP_URL=https://techrepairpro.vercel.app
# SUPABASE_URL=https://xxxx.supabase.co         (auto-injected)
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxx              (auto-injected)
#
# ─── Webhook URL to configure in MP dashboard ─────────────────
# https://xxxx.supabase.co/functions/v1/mp-webhook
#
# Events to subscribe: payment, subscription_preapproval, subscription_authorized_payment
# ─────────────────────────────────────────────────────────────
