{
  "name": "techrepair-pro",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "vercel-build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "lint:errors": "eslint src --ext .ts,.tsx --quiet",
    "lint:ci": "eslint src --ext .ts,.tsx --max-warnings 100",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:finance": "playwright test --grep @finance",
    "test:e2e:suppliers": "playwright test --grep @suppliers",
    "test:e2e:orders": "playwright test --grep @orders",
    "test:e2e:customers": "playwright test --grep @customers"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "@supabase/supabase-js": "^2.102.1",
    "bootstrap": "^5.3.3",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.363.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "react-to-print": "^3.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.8"
  }
}
