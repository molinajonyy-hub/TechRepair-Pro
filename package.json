{
  "name": "techrepair-pro",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "vercel-build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "lint:errors": "eslint src --ext .ts,.tsx --quiet",
    "lint:ci": "eslint src --ext .ts,.tsx --max-warnings 100",
    "typecheck": "tsc --noEmit",
    "guard:finance-writes": "node scripts/guards/no-direct-finance-writes.mjs",
    "guard:finance-writes:self-test": "node scripts/guards/no-direct-finance-writes.mjs --self-test",
    "guard:secdef": "node scripts/finance/guard-security-definer.mjs",
    "guard:secdef:self-test": "node scripts/finance/guard-security-definer.mjs --self-test",
    "guard:readonly-sql": "node scripts/finance/guard-readonly-sql.mjs docs/auditoria-finanzas/m7/m7-preflight-productivo-conjunto.sql docs/auditoria-finanzas/m7/6f4-preflight-anulaciones.sql",
    "guard:readonly-healthcheck": "node scripts/finance/guard-readonly-healthcheck.mjs",
    "guard:visual-evidence": "node scripts/finance/guard-visual-evidence.mjs",
    "guard:visual-evidence:self-test": "node scripts/finance/guard-visual-evidence.mjs --self-test",
    "guards": "npm run guard:finance-writes:self-test && npm run guard:finance-writes && npm run guard:secdef:self-test && npm run guard:secdef && npm run guard:readonly-sql && npm run guard:readonly-healthcheck && npm run guard:visual-evidence:self-test",
    "validate:m6": "node scripts/finance/run-m6-validation.mjs",
    "test:unit": "node --test \"tests/unit/**/*.test.ts\"",
    "dev:e2e": "vite --mode e2e --port 5174 --strictPort",
    "e2e:prepare": "node scripts/e2e/prepare-local.mjs",
    "e2e:m7": "playwright test --project=m7-local",
    "e2e:m7:ui": "playwright test --project=m7-local --ui",
    "e2e:m7:evidencia": "playwright test --project=m7-local --grep @visual --update-snapshots",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:finance": "playwright test --grep @finance",
    "test:e2e:suppliers": "playwright test --grep @suppliers",
    "test:e2e:orders": "playwright test --grep @orders",
    "test:e2e:customers": "playwright test --grep @customers"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "@supabase/supabase-js": "^2.102.1",
    "bootstrap": "^5.3.3",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.363.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "react-to-print": "^3.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.8"
  }
}
