VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Analítica de la landing (opcional).
# Microsoft Clarity: si se define, la landing carga Clarity con este project id.
# Si queda vacío, la integración es no-op (no se carga ningún script).
VITE_CLARITY_PROJECT_ID=

# Contacto público de la landing (opcional).
# Si una variable queda vacía, el enlace NO se renderiza (evita contactos ficticios).
#   WhatsApp: sólo dígitos con código de país, p. ej. 549351XXXXXXX
#   Instagram: usuario sin @
VITE_CONTACT_WHATSAPP=
VITE_CONTACT_EMAIL=
VITE_CONTACT_INSTAGRAM=
