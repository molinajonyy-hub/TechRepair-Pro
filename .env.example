VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Analítica de la landing — TODAS opcionales. La app funciona sin ellas (no-op).
# Los scripts se cargan desde el código (src/lib/analytics.ts), NO pegar snippets
# manualmente en index.html. No commitear IDs/datos reales: cargarlos en Vercel.
#
# Google Analytics 4 (gtag.js). Formato G-XXXXXXXXXX. Si falta o es inválido, no
# se carga gtag.js y los eventos internos siguen funcionando.
VITE_GA_MEASUREMENT_ID=
# Microsoft Clarity: si se define, la landing carga Clarity con este project id.
VITE_CLARITY_PROJECT_ID=

# Contacto público de la landing (opcional).
# Si una variable queda vacía, el enlace NO se renderiza (evita contactos ficticios).
#   WhatsApp: sólo dígitos con código de país, p. ej. 549351XXXXXXX
#   Instagram: usuario sin @
VITE_CONTACT_WHATSAPP=
VITE_CONTACT_EMAIL=
VITE_CONTACT_INSTAGRAM=
